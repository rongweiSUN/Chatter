# 火山引擎大模型语音识别 V3 API 配置
# 从火山引擎控制台获取: https://console.volcengine.com/speech/app

# 鉴权方式: app_key（默认）或 app_id_token
# VOLCENGINE_AUTH_METHOD=app_key

# App Key 鉴权（新版控制台）
VOLCENGINE_APP_KEY=your_app_key

# App ID + Token 鉴权（旧版控制台，仅 auth_method=app_id_token 时需要）
# VOLCENGINE_APPID=your_app_id
# VOLCENGINE_TOKEN=your_access_token

# Resource ID（默认 volc.seedasr.sauc.duration）
VOLCENGINE_RESOURCE_ID=volc.seedasr.sauc.duration
